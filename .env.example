# Database Configuration
DATABASE_URL="mongodb+srv://your_db_user:your_db_password@your_cluster.mongodb.net/your_db_name"

# Google OAuth Credentials (Web)
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Google OAuth Credentials (Android Native)
GOOGLE_ANDROID_CLIENT_ID="your_google_android_client_id.apps.googleusercontent.com"

# Google Gemini AI Key
GOOGLE_GENERATIVE_AI_API_KEY="your_google_generative_ai_api_key"

# Nodemailer / Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="example@gmail.com"
EMAIL_PASS="your_app_specific_password"
FROM_EMAIL="example@gmail.com"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_generated_nextauth_secret_key"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Firebase Admin SDK Configuration (For Push Notifications)
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-fbsvc@your_firebase_project_id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nFirebase\nPrivate\nKey\nHere\n-----END PRIVATE KEY-----\n"

# Usptash Configuration details
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url